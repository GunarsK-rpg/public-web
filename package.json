{
  "name": "cosmere-rpg",
  "version": "0.0.1",
  "description": "Character sheet manager for Cosmere RPG",
  "productName": "Cosmere RPG",
  "author": "GunarsK <gunarskunakovs@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "quasar dev -m pwa",
    "build": "quasar build -m pwa",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "@sentry/vue": "^10.46.0",
    "axios": "^1.14.0",
    "cropperjs": "^2.1.0",
    "dompurify": "^3.3.3",
    "lucide-vue-next": "^1.0.0",
    "marked": "^17.0.5",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "quasar": "^2.19.2",
    "register-service-worker": "^1.7.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@quasar/app-vite": "^2.5.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6",
    "workbox-build": "^7.4.0"
  },
  "engines": {
    "node": "^24.14.1",
    "npm": ">= 11.12.1",
    "yarn": ">= 1.22.22"
  },
  "overrides": {
    "lodash": "4.18.1",
    "serialize-javascript": "^7.0.5",
    "smol-toml": "^1.6.1"
  }
}
