{
  "name": "cosmere-rpg",
  "version": "0.0.1",
  "description": "Character sheet manager for Cosmere RPG",
  "productName": "Cosmere RPG",
  "author": "GunarsK <gunarskunakovs@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "axios": "^1.13.2",
    "pinia": "^3.0.4",
    "pino": "^10.2.0",
    "quasar": "^2.18.6",
    "vue": "^3.5.26",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.17",
    "@eslint/js": "^9.39.2",
    "@intlify/unplugin-vue-i18n": "^11.0.3",
    "@quasar/app-vite": "^2.4.0",
    "@types/node": "^24",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.0.0",
    "markdownlint-cli2": "^0.20.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite-plugin-checker": "^0.12.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.2",
    "vitest": "^4.0.17",
    "jsdom": "^27.4.0"
  },
  "engines": {
    "node": "^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
